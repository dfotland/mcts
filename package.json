{
  "name": "@smart-games/mcts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Game-agnostic Monte Carlo Tree Search library for Smart Games SPAs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./worker": {
      "import": "./dist/worker.js"
    },
    "./worker-host": {
      "types": "./worker-host.d.ts",
      "import": "./dist/worker-host.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "demo:ttt": "vitest run src/games/tic-tac-toe/demo.test.ts",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@types/node": "^22.17.2",
    "eslint": "^9.33.0",
    "globals": "^16.3.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.1",
    "vite": "^5.4.19",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.9"
  }
}
